# o2switch: PHP 8.4 for API front controller
<FilesMatch \.php$>
  SetHandler application/x-httpd-php84
</FilesMatch>
AddHandler application/x-httpd-php84 .php
suPHP_ConfigPath /home/race8462/academy.clouddevfusion.com/race8462/intranet/

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /intranet/api/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^ index.php [L]
</IfModule>
