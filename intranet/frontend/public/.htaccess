RewriteEngine On
RewriteBase /intranet/

# Pass Authorization header to Symfony
RewriteCond %{HTTP:Authorization} .
RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# API → Symfony backend (PATH_INFO = /intranet/api/...)
RewriteRule ^api(?:/(.*))?$ backend/public/index.php/intranet/api/$1 [L,QSA]

# Keep existing files/directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SPA fallback (HTML5 routes only)
RewriteRule ^ index.html [L]
