# o2switch: force PHP 8.4 for /intranet/ (Symfony 8)
# https://faq.o2switch.fr/guides/php/changer-version-php-et-php-ini/
<FilesMatch \.php$>
  SetHandler application/x-httpd-php84
</FilesMatch>
AddHandler application/x-httpd-php84 .php
suPHP_ConfigPath /home/race8462/academy.clouddevfusion.com/race8462/intranet/
