Options -Indexes

RewriteEngine On

# Pass Authorization header to PHP
RewriteCond %{HTTP:Authorization} .
RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Serve real files directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# ===== INTRANET STATIC FILES =====
# Map /intranet/* to intranet/frontend/* for static files
RewriteCond intranet/frontend/%1 -f
RewriteRule ^intranet/(.+\.(js|css|ico|png|jpg|svg|woff|woff2|ttf|map))$ intranet/frontend/$1 [L]

# ===== INTRANET API ROUTING =====
RewriteCond %{REQUEST_URI} !^/intranet/backend/public/index\.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} ^/intranet/api
RewriteRule ^intranet/api(/.*)?$ intranet/backend/public/index.php [L,QSA]

# ===== MAIN API ROUTING =====
RewriteRule ^api($|/.*)$ backend/public/index.php [L,QSA]

# ===== SPA ROUTING =====
RewriteRule ^intranet$ /intranet/ [R=301,L]

# Intranet SPA fallback
RewriteCond %{REQUEST_URI} ^/intranet/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^intranet/(.*)$ intranet/frontend/index.html [L]

# Main app SPA fallback
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.html [L]