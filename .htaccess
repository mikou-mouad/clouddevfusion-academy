RewriteEngine On

# ─── INTRANET API → front controller in intranet/api/ ───
RewriteRule ^intranet/api(?:/.*)?$ intranet/api/index.php [L,QSA]

# Pass Authorization header to PHP
RewriteCond %{HTTP:Authorization} .
RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# ─── GLOBAL API → Symfony front controller ──────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/(.*)$ backend/public/index.php [L,QSA]

# ─── INTRANET ANGULAR (HTML5 routing, exclude API) ──────────────────────────
RewriteCond %{REQUEST_URI} !^/intranet/api [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^intranet/(.*)$ intranet/index.html [L]

# ─── GLOBAL ANGULAR (HTML5 routing) ─────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]
